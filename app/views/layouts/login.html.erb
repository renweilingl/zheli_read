<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "浙里阅读" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1">
    <meta charset="utf-8">
    <meta name="renderer" content="webkit">
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%= stylesheet_link_tag 'application', media: 'all' %>
    <%= javascript_include_tag 'application', 'data-turbolinks-track': 'reload' %>

    <style>
      :root {
        --primary-color: #52c41a;
        --primary-light: #73d13d;
        --primary-dark: #389e0d;
        --bg-gradient-start: #f0f9eb;
        --bg-gradient-end: #e8f5e1;
        --card-bg: #ffffff;
        --text-primary: #262626;
        --text-secondary: #8c8c8c;
        --border-color: #d9d9d9;
        --shadow-sm: 0 2px 8px rgba(82, 196, 26, 0.08);
        --shadow-md: 0 4px 20px rgba(82, 196, 26, 0.12);
        --shadow-lg: 0 8px 40px rgba(82, 196, 26, 0.16);
      }

      body {
        background: linear-gradient(135deg, var(--bg-gradient-start) 0%, var(--bg-gradient-end) 100%);
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        padding: 20px;
        margin: 0;
      }

      body::before {
        content: '';
        position: fixed;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(circle at 20% 80%, rgba(82, 196, 26, 0.08) 0%, transparent 50%),
                  radial-gradient(circle at 80% 20%, rgba(82, 196, 26, 0.06) 0%, transparent 50%);
        z-index: -1;
        animation: float 20s ease-in-out infinite;
      }

      @keyframes float {
        0%, 100% { transform: translate(0, 0); }
        50% { transform: translate(-2%, 2%); }
      }

      .login-card {
        width: 100%;
        max-width: 520px;
        background: var(--card-bg);
        border-radius: 16px;
        box-shadow: var(--shadow-lg);
        overflow: hidden;
        animation: slideUp 0.6s ease-out;
      }

      @keyframes slideUp {
        from {
          opacity: 0;
          transform: translateY(30px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      .login-header {
        background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
        padding: 40px 30px;
        text-align: center;
        position: relative;
        overflow: hidden;
      }

      .login-header::before {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(circle at 30% 70%, rgba(255, 255, 255, 0.15) 0%, transparent 50%);
      }

      .login-header::after {                                                       
        content: '';                                                               
        position: absolute;                                                        
        bottom: 0;                                                                 
        left: 0;                                                                   
        right: 0;                                                                  
        height: 30px;                                                              
        background: var(--card-bg);                                                
        border-radius: 50% 50% 0 0;                                                
      }                                                                            
                                                                                 
      .login-logo {                                                                
        width: 72px;                                                               
        height: 72px;                                                              
        background: rgba(255, 255, 255, 0.2);                                      
        border-radius: 50%;                                                        
        display: flex;                                                             
        align-items: center;                                                       
        justify-content: center;                                                   
        margin: 0 auto 16px;                                                       
        backdrop-filter: blur(10px);                                               
        border: 3px solid rgba(255, 255, 255, 0.3);                                
        position: relative;                                                        
        z-index: 1;                                                                
      }                                                                            
                                                                                 
      .login-logo .layui-icon {                                                    
        font-size: 36px;                                                           
        color: white;                                                              
      } 

      .login-header h1 {                                                           
        font-size: 24px;                                                           
        font-weight: 600;                                                          
        color: white;                                                              
        margin: 0 0 8px 0;                                                         
        position: relative;                                                        
        z-index: 1;                                                                
      }                                                                            
                                                                                 
      .login-header p {                                                            
        font-size: 14px;                                                           
        color: rgba(255, 255, 255, 0.85);                                          
        margin: 0;                                                                 
        position: relative;                                                        
        z-index: 1;                                                                
      }                                                                            
                                                                                 
      .login-body {                                                                
        padding: 35px 30px 40px;                                                   
      }                                                                            
                                                                                 
      .layui-form-item {                                                           
        margin-bottom: 24px;                                                       
      }
      .layui-form-label {                                                          
        padding: 0 0 8px 0;
        width: auto;                                                               
        font-size: 14px;                                                           
        color: var(--text-primary);                                                
      }                                                                            
                                                                                 
      .layui-input {                                                               
        height: 48px;                                                              
        border: 2px solid var(--border-color);                                     
        border-radius: 10px;                                                       
        font-size: 15px;                                                           
        padding: 0 16px;                                                           
        transition: all 0.3s ease;                                                 
      }                                                                            
                                                                                 
      .layui-input:hover {                                                         
        border-color: var(--primary-light);                                        
      }                                                                            
                                                                                 
      .layui-input:focus {                                                         
        border-color: var(--primary-color);                                        
        box-shadow: 0 0 0 3px rgba(82, 196, 26, 0.1);                              
      }                                                                            
                                                                                 
      .layui-input-prefix {                                                        
        left: 14px;                                                                
        font-size: 20px;                                                           
        color: var(--text-secondary);                                              
      }
      .layui-input-wrap {                                                          
        position: relative;                                                        
      }                                                                            
                                                                                 
      .input-with-icon .layui-input {                                              
        padding-left: 46px;                                                        
      }                                                                            
                                                                                 
      .input-with-icon .layui-input:focus + .input-icon,                           
      .input-with-icon .layui-input:focus ~ .layui-input-prefix {                  
        color: var(--primary-color);                                               
      }                                                                            
                                                                                 
      .layui-btn-login {                                                           
        width: 100%;                                                               
        height: 48px;                                                              
        background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
        border: none;                                                              
        border-radius: 10px;                                                       
        font-size: 16px;                                                           
        font-weight: 600;                                                          
        color: white;                                                              
        cursor: pointer;                                                           
        transition: all 0.3s ease;                                                 
        display: flex;                                                             
        align-items: center;                                                       
        justify-content: center;                                                   
        gap: 8px;                                                                  
      }

      .layui-btn-login:hover {                                                     
        background: linear-gradient(135deg, var(--primary-light) 0%, var(--primary-color) 100%);
        transform: translateY(-2px);                                               
        box-shadow: 0 6px 20px rgba(82, 196, 26, 0.35);                            
      }                                                                            
                                                                                 
      .layui-btn-login:active {                                                    
        transform: translateY(0);                                                  
      }                                                                            
                                                                                 
      .layui-btn-login .layui-icon {                                               
        font-size: 18px;                                                           
      }                                                                            
                                                                                 
      .layui-form-mid.error {                                                      
        color: #ff4d4f;                                                            
        font-size: 12px;                                                           
        margin-top: 4px;                                                           
      } 
      @media screen and (max-width: 480px) {                                       
        .login-card {                                                              
          border-radius: 12px;                                                     
        }                                                                          
                                                                                 
        .login-header {                                                            
          padding: 30px 20px;                                                      
        }                                                                          
                                                                                 
        .login-body {                                                              
          padding: 25px 20px 30px;
        }
        .layui-input {
          height: 44px;
        }
      }
    </style>
  </head>

  <body>
    <%= yield %>
  </body>
</html>
