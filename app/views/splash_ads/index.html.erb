<div class="layui-card">
  <div class="layui-card-header">
    <h3>开屏广告管理</h3>
  </div>
  <div class="layui-card-body">
    <div class="layui-form" style="margin-bottom: 15px;">
      <div class="layui-inline">
        <%= link_to '新建广告', new_splash_ad_path, class: 'layui-btn layui-btn-normal' %>
      </div>
      <div class="layui-inline">
        <label class="layui-form-label" style="width: 80px;">状态：</label>
        <div class="layui-input-inline" style="width: 120px;">
          <select name="status" lay-filter="status-filter">
            <option value="">全部</option>
            <option value="draft" <%= params[:status] == 'draft' ? 'selected' : '' %>>草稿</option>
            <option value="active" <%= params[:status] == 'active' ? 'selected' : '' %>>投放中</option>
            <option value="expired" <%= params[:status] == 'expired' ? 'selected' : '' %>>已过期</option>
            <option value="disabled" <%= params[:status] == 'disabled' ? 'selected' : '' %>>已停用</option>
          </select>
        </div>
      </div>
      <div class="layui-inline">
        <label class="layui-form-label" style="width: 80px;">链接类型：</label>
        <div class="layui-input-inline" style="width: 120px;">
          <select name="link_type" lay-filter="link-type-filter">
            <option value="">全部</option>
            <option value="single_book" <%= params[:link_type] == 'single_book' ? 'selected' : '' %>>单本书</option>
            <option value="category" <%= params[:link_type] == 'category' ? 'selected' : '' %>>分类目录</option>
          </select>
        </div>
      </div>
    </div>

    <!--table class="layui-table" lay-size="sm"-->
    <table class="layui-table">
      <thead>
        <tr>
          <th style="width: 50px;">ID</th>
          <th style="width: 100px;">广告图片</th>
          <th>链接类型</th>
          <th>推送范围</th>
          <th>推送方式</th>
          <th>投放时间</th>
          <th>状态</th>
          <th>发送数</th>
          <th>点击数</th>
          <th>送达率</th>
          <th style="width: 180px;">操作</th>
        </tr>
      </thead>
      <tbody>
        <% @splash_ads.each do |ad| %>
        <tr>
          <td><%= ad.id %></td>
          <td>
            <% if ad.image_url.present? %>
              <img src="<%= ad.image_url %>" alt="广告图" style="width: 80px; height: 60px; object-fit: cover; border-radius: 4px;">
            <% end %>
          </td>
          <td><%= ad.link_type_name %></td>
          <td><%= ad.push_scope_name %></td>
          <td><%= ad.push_mode_name %></td>
          <td style="font-size: 12px;"><%= ad.time_range_display %></td>
          <td>
            <%
              status_class = case ad.status
              when 'draft' then 'layui-bg-gray'
              when 'scheduled' then 'layui-bg-blue'
              when 'active' then 'layui-bg-green'
              when 'expired' then 'layui-bg-orange'
              when 'disabled' then 'layui-bg-red'
              end
            %>
            <span class="layui-badge <%= status_class %>"><%= ad.status_name %></span>
          </td>
          <td><%= ad.send_count %></td>
          <td><%= ad.click_count %></td>
          <td><%= ad.delivery_rate_display %></td>
          <td>
            <div class="layui-btn-container">
              <%= link_to '查看', splash_ad_path(ad), class: 'layui-btn layui-btn-xs layui-btn-normal' %>
              <% if policy(ad).edit? %>
                <%= link_to '编辑', edit_splash_ad_path(ad), class: 'layui-btn layui-btn-xs' %>
              <% end %>
              <% if ad.can_publish? && policy(ad).publish? %>
                <button class="layui-btn layui-btn-xs layui-btn-warm" onclick="publishAd(<%= ad.id %>)">发布</button>
              <% end %>
            </div>
          </td>
        </tr>
        <% end %>
      </tbody>
    </table>

  </div>
</div>

<script>
layui.use(['form', 'layer'], function() {
  var form = layui.form;
  var layer = layui.layer;
});

// 发布广告
function publishAd(id) {
  layui.layer.confirm('确定要发布该广告吗？', function(index) {
    $.ajax({
      url: '/admin/splash_ads/' + id + '/publish',
      type: 'POST',
      success: function(res) {
        if (res.success) {
          layui.layer.msg('发布成功', { icon: 1 }, function() {
            location.reload();
          });
        } else {
          layui.layer.msg(res.errors ? res.errors.join(', ') : '发布失败', { icon: 2 });
        }
      },
      error: function() {
        layui.layer.msg('发布失败', { icon: 2 });
      }
    });
    layui.layer.close(index);
  });
}
</script>
