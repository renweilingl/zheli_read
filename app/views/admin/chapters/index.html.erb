<div class="layui-tab">
  <div class="x-nav">
    <span class="layui-breadcrumb">
      <a>有声视频</a>
      <a><cite><%= @book.name %></cite></a>
      <a><cite>内容管理</cite></a>
    </span>
    <%= render 'common/user_info' %>
  </div>

  <div class="x-body">
    <div class="layui-row">
      <div class="xblock">
        <div class="layui-col-xs9">
          <button class="layui-btn layui-bg-blue layui-btn-sm" onclick="batchFree();">批量免费</button>
          <button class="layui-btn layui-bg-blue layui-btn-sm" onclick="batchUnfree();">批量收费</button>
        </div>
        <div class="layui-col-3 text-right">
          <%= link_to batch_new_admin_media_book_chapters_path(@book), class: 'layui-btn layui-bg-blue' do %>
            <i class="layui-icon layui-icon-upload"></i>批量上传
          <% end %>

          <%= link_to new_admin_media_book_chapter_path(@book), class: 'layui-btn layui-bg-blue' do %>
            <i class="layui-icon"></i>新增单本
          <% end %>
        </div>
      </div>
    </div>

    <table class="layui-table" id="main-table"></table>
  </div>
</div>

<script type="text/html" id="tool-wrapper">
  <div class="layui-btn-group">
    <a href="/admin/media_books/<%= @book.id %>/chapters/{{d.id}}/edit" class="layui-btn layui-btn-sm">编辑</a>
    <a data-method="delete" href="/admin/media_books/<%= @book.id %>/chapters/{{d.id}}" class="layui-btn layui-btn-sm layui-bg-red" data-confirm="确实要删除吗？">删除
</a>
  </div>
</script>

<script>
    layui.use(['table'],function(){
      var table = layui.table;
      table.render({
        elem: '#main-table',
        url: '<%= admin_media_book_chapters_path(@book) %>',
        page: {
          layout: ['count', 'prev', 'page', 'next', 'limit', 'skip'],
          groups: 10,
          limit: 50,
          theme: '#1E9FFF',
          first: '首页',
          last: '尾页',
          prev: '<em>←</em>',
          next: '<em>→</em>',
        },
        cols: [[
          {type: 'checkbox', data: 'id'},
          {field: 'id', title: 'ID', hide: true},
          {field: 'book_id', title: 'book_id', hide: true},
          {field: 'sn', title: '序号', sort: true, edit: "number", width: 80},
          {field: 'name', title: '单本名'},
          //{field: 'content_file_name', title: '文件'},
          {field: 'is_free', title: '付费类型', align: "center", width: 100, templet: function(d){
              if(d.is_free == true){
                return '<span class="layui-badge layui-bg-green">免费</span>';
              } else {
                return '<span class="layui-badge layui-bg-gray">付费</span>';
              }
            }
          },
          {field: 'is_published', title: '单本状态', align: "center", width: 100, templet: function(d){
              if(d.is_published == true){
                return '<span class="layui-badge layui-bg-green">在线</span>';
              } else {
                return '<span class="layui-badge layui-bg-gray">未发布</span>';
              }
            }
          },
          {field: 'created_at', title: '上线时间'},
          {title: '操作', templet: '#tool-wrapper', align: "center", width: 170},
        ]],
      });

      table.on('edit(main-table)', function(obj){                                
        var value = obj.value // 得到修改后的值
        var data = obj.data // 得到所在行所有键值
        var field = obj.field; // 得到字段

        $.ajax({
          url: '<%= update_sn_admin_media_book_chapters_path(@book) %>',
          dataType: 'json',
          type: 'post',
          data: {id: data.id, sn: data.sn},
          success: function(res) {
            if(res.code == 0){
              var update = {};
              update[field] = value;
              obj.update(update);
              layer.msg('修改成功');
            } else {
              layer.msg('修改失败');
            }
          }
        })
      });
    })

    function get_ids() {
        var table = layui.table;
        let ctrCheckArr = [];
        ctrCheckArr.length = 0;
        let checkStatus = table.checkStatus('main-table'),
            data = checkStatus.data; //获取选中的数据
        for (let i = 0; i < data.length; i++) {
            ctrCheckArr.push(data[i].id)
        }
        return ctrCheckArr;
    }

    function batchFree() {
        var ids = get_ids();

        $.ajax({
          url: '<%= batch_free_admin_media_book_chapters_path(@book) %>',
          dataType: 'json',
          type: 'post',
          data: {ids: ids},
          success: function(res) {
            if(res.code == 0){
              window.location.reload();
            } else {
              layer.msg('修改失败');
            }
          }
        })
    }

    function batchUnfree() {
        var ids = get_ids();

        $.ajax({
          url: '<%= batch_unfree_admin_media_book_chapters_path(@book) %>',
          dataType: 'json',
          type: 'post',
          data: {ids: ids},
          success: function(res) {
            if(res.code == 0){
              window.location.reload();
            } else {
              layer.msg('修改失败');
            }
          }
        })
    }
</script>
