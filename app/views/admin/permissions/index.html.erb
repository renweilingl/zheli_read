<div class="layui-tab">
  <div class="x-nav">
    <span class="layui-breadcrumb">
      <a href="">权限设置</a>
      <a><cite>角色管理</cite></a>
    </span>
    <%= render 'common/user_info' %>
  </div>
</div>

<div class="layui-row layui-col-space15" style="margin-bottom: 15px;">
  <div class="layui-col-md4">
    <div class="layui-card">
      <div class="layui-card-body" style="background: linear-gradient(135deg, #16a34a, #10b981); border-radius: 4px; color: white;">
        <div style="font-size: 32px; font-weight: bold;">1</div>
        <div style="opacity: 0.9;">总权限数</div>
      </div>
    </div>
  </div>
  <div class="layui-col-md4">
    <div class="layui-card">
      <div class="layui-card-body" style="background: linear-gradient(135deg, #3b82f6, #2563eb); border-radius: 4px; color: white;">
        <div style="font-size: 32px; font-weight: bold;">2</div>
        <div style="opacity: 0.9;">启用权限</div>
      </div>
    </div>
  </div>
  <div class="layui-col-md4">
    <div class="layui-card">
      <div class="layui-card-body" style="background: linear-gradient(135deg, #6b7280, #4b5563); border-radius: 4px; color: white;">
        <div style="font-size: 32px; font-weight: bold;">3</div>
        <div style="opacity: 0.9;">禁用权限</div>
      </div>
    </div>
  </div>
</div>

<!-- 权限列表 -->
<div class="layui-card">
  <div class="layui-card-header">
    权限列表
    <div style="float: right;">
      <div class="layui-inline">
        <input type="text" placeholder="搜索权限..." id="search-input" class="layui-input" style="width: 200px;">
        <button class="layui-btn layui-btn-primary layui-btn-sm" onclick="searchPolicies()">
          <i class="layui-icon layui-icon-search"></i>
        </button>
      </div>
    </div>
  </div>
  <div class="layui-card-body">
    <table class="layui-table" lay-skin="line">
      <thead>
        <tr>
          <th width="80">ID</th>
          <th>权限名称</th>
          <th>代码</th>
          <th>描述</th>
          <th>状态</th>
          <th width="200">操作</th>
        </tr>
      </thead>
      <tbody>
        <% if @policies.empty? %>
          <tr>
            <td colspan="6" style="text-align: center; padding: 40px 0;">
              <i class="layui-icon layui-icon-face-cry" style="font-size: 48px; color: #999;"></i>
              <div style="color: #999; margin-top: 10px;">暂无权限数据</div>
            </td>
          </tr>
        <% else %>
          <% @policies.each do |policy| %>
            <tr>
              <td><%= policy.id %></td>
              <td>
                <div style="display: flex; align-items: center; gap: 10px;">
                  <div style="width: 36px; height: 36px; background: linear-gradient(135deg, #dbeafe, #bfdbfe); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: #2563eb; font-weight: bold; font-size: 16px;">
                    <i class="layui-icon layui-icon-vercode"></i>
                  </div>
                  <span><%= policy.name %></span>
                </div>
              </td>
              <td><code><%= policy.code %></code></td>
              <td style="max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                <%= policy.description || '-' %>
              </td>
              <td>
                <% if policy.enabled %>
                  <span class="layui-badge layui-bg-green">启用</span>
                <% else %>
                  <span class="layui-badge layui-bg-gray">禁用</span>
                <% end %>
              </td>
              <td>
                <div class="layui-btn-group">
                  <%= link_to admin_permission_path(policy), class: "layui-btn layui-btn-xs", title: "查看详情" do %>
                    <i class="layui-icon layui-icon-read"></i>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        <% end %>
      </tbody>
    </table>

    <!-- 分页 -->
    <% if @policies.total_pages > 1 %>
      <div id="pagination" style="margin-top: 20px;"></div>
    <% end %>
  </div>
</div>

<style>
  .layui-btn-group .layui-btn {
    margin: 0;
  }

  .layui-btn-xs {
    padding: 0 8px;
    height: 24px;
    line-height: 24px;
    font-size: 12px;
  }

  .layui-badge {
    padding: 4px 10px;
    border-radius: 12px;
    font-size: 12px;
  }
</style>

<script>
  layui.use(['laypage'], function(){
    var laypage = layui.laypage;

    // 分页
    <% if @policies.total_pages > 1 %>
    laypage.render({
      elem: 'pagination',
      count: <%= @policies.total_entries %>,
      limit: <%= @policies.per_page %>,
      curr: <%= @policies.current_page %>,
      layout: ['count', 'prev', 'page', 'next', 'limit', 'skip'],
      jump: function(obj, first){
        if(!first){
          var url = new URL(window.location.href);
          url.searchParams.set('page', obj.curr);
          url.searchParams.set('per_page', obj.limit);
          window.location.href = url.toString();
        }
      }
    });
    <% end %>

    // 搜索功能
    function searchPolicies() {
      var searchValue = document.getElementById('search-input').value;
      var url = new URL(window.location.href);
      if (searchValue) {
        url.searchParams.set('search', searchValue);
      } else {
        url.searchParams.delete('search');
      }
      window.location.href = url.toString();
    }

    // 回车搜索
    document.getElementById('search-input').addEventListener('keyup', function(e){
      if(e.keyCode === 13){
        searchPolicies();
      }
    });

    // 快捷键
    document.addEventListener('keydown', function(e){
      // Ctrl/Cmd + / 聚焦搜索框
      if((e.ctrlKey || e.metaKey) && e.key === '/'){
        e.preventDefault();
        document.getElementById('search-input').focus();
      }
    });
  });
</script>
