<div class="admin-content">
  <div class="content-header">
    <div class="breadcrumb">
      <%= link_to "分类管理", admin_categories_path, class: "breadcrumb-item" %>
      <span class="breadcrumb-separator">/</span>
      <span class="breadcrumb-current">推荐分类</span>
    </div>
    <div class="content-actions">
      <%= link_to admin_categories_path, class: "btn-secondary" do %>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
        </svg>
        返回
      <% end %>
    </div>
  </div>

  <div class="content-grid">
    <!-- 左侧：推荐分类列表 -->
    <div class="content-main">
      <div class="table-container">
        <div class="table-header">
          <div class="table-title">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
            </svg>
            推荐分类列表
          </div>
        </div>

        <div class="table-body">
          <% if @categories.any? %>
            <div class="recommended-grid">
              <% @categories.each do |category| %>
                <div class="recommended-card">
                  <div class="recommended-header">
                    <div class="recommended-icon">
                      <%= category.name[0].upcase %>
                    </div>
                    <span class="badge-count"><%= category.children_count %></span>
                  </div>
                  <div class="recommended-body">
                    <h4 class="recommended-title"><%= category.name %></h4>
                    <% if category.description.present? %>
                      <p class="recommended-desc"><%= truncate(category.description, length: 100) %></p>
                    <% end %>
                  </div>
                  <div class="recommended-footer">
                    <div class="recommended-meta">
                      <span>排序: <%= category.sort_order %></span>
                      <span>•</span>
                      <span><%= category.updated_at.strftime('%Y-%m-%d') %></span>
                    </div>
                    <%= link_to admin_category_path(category), class: "btn-link-small" do %>
                      查看详情
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                      </svg>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="empty-state">
              <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
              </svg>
              <p>暂无推荐分类</p>
              <p class="empty-hint">使用下方表单创建推荐分类</p>
            </div>
          <% end %>
        </div>

        <div class="table-footer">
          <div class="table-info">
            共 <%= @categories.total_entries %> 个推荐分类，第 <%= @categories.current_page %> / <%= @categories.total_pages %> 页
          </div>
          
          <!-- 每页显示数量选择 -->
          <div class="table-per-page">
            <label for="perPage">每页显示：</label>
            <select id="perPage" onchange="changePerPage(this.value)" class="per-page-select">
              <option value="6" <%= 'selected' if @per_page.to_i == 6 %>>6</option>
              <option value="12" <%= 'selected' if @per_page.to_i == 12 %>>12</option>
              <option value="24" <%= 'selected' if @per_page.to_i == 24 %>>24</option>
              <option value="48" <%= 'selected' if @per_page.to_i == 48 %>>48</option>
            </select>
          </div>
          
          <!-- 分页导航 -->
          <%= paginate @categories, :param_name => :page %>
        </div>
      </div>
    </div>

    <!-- 右侧：新建推荐分类 -->
    <div class="content-sidebar">
      <div class="form-card">
        <div class="form-header">
          <div class="form-header-content">
            <div class="form-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
              </svg>
            </div>
            <div>
              <h3 class="form-title">新建推荐分类</h3>
              <p class="form-description">创建新的推荐分类</p>
            </div>
          </div>
        </div>

        <%= form_with(url: create_recommended_admin_categories_path, method: :post, local: true, class: "form-body") do |form| %>
          <div class="form-group">
            <label class="form-label">分类名称 *</label>
            <div class="form-input-wrapper">
              <div class="form-input-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                </svg>
              </div>
              <%= text_field_tag :name, nil,
                  placeholder: "请输入推荐分类名称",
                  required: true,
                  class: "form-input" %>
            </div>
          </div>

          <div class="form-group">
            <label class="form-label">排序</label>
            <div class="form-input-wrapper">
              <div class="form-input-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 4h13M3 8h9m-9 4h6m4 0l4-4m0 0l4 4m-4-4v12"/>
                </svg>
              </div>
              <%= number_field_tag :sort_order, 0,
                  min: 0,
                  class: "form-input" %>
            </div>
            <p class="form-hint">数字越小排序越靠前</p>
          </div>

          <div class="form-group">
            <label class="form-label">描述</label>
            <div class="form-input-wrapper">
              <%= text_area_tag :description, nil,
                  rows: 3,
                  placeholder: "请输入推荐分类描述（可选）",
                  class: "form-textarea" %>
            </div>
          </div>

          <div class="form-actions">
            <%= submit_tag "创建推荐分类", class: "btn-submit" do %>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
              </svg>
              创建推荐分类
            <% end %>
          </div>
        <% end %>
      </div>

      <!-- 提示信息 -->
      <div class="info-card">
        <div class="info-card-header">
          <h3 class="info-card-title">使用提示</h3>
        </div>
        <div class="info-card-body">
          <ul class="tips-list">
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              推荐分类独立于年级分类体系
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              用于内容推荐和分类展示
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              可以为内容设置多个推荐分类
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              支持自定义排序顺序
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
.breadcrumb {
  display: flex;
  align-items: center;
  gap: 8px;
  color: #6b7280;
  font-size: 14px;
}

.breadcrumb-item {
  color: #6b7280;
  text-decoration: none;
  transition: color 0.2s;
}

.breadcrumb-item:hover {
  color: #10b981;
}

.breadcrumb-separator {
  color: #9ca3af;
}

.breadcrumb-current {
  color: #111827;
  font-weight: 500;
}

.content-grid {
  display: grid;
  grid-template-columns: 1fr 380px;
  gap: 24px;
}

.content-main {
  display: flex;
  flex-direction: column;
}

.content-sidebar {
  display: flex;
  flex-direction: column;
  gap: 24px;
}

.table-container {
  background: white;
  border-radius: 12px;
  border: 1px solid #e5e7eb;
  overflow: hidden;
}

.table-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20px 24px;
  background: #f9fafb;
  border-bottom: 1px solid #e5e7eb;
}

.table-title {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 16px;
  font-weight: 600;
  color: #111827;
}

.table-body {
  padding: 24px;
}

.recommended-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16px;
}

.recommended-card {
  border: 1px solid #e5e7eb;
  border-radius: 10px;
  padding: 16px;
  transition: all 0.2s;
  background: white;
}

.recommended-card:hover {
  border-color: #fbbf24;
  box-shadow: 0 4px 12px rgba(251, 191, 36, 0.1);
  transform: translateY(-2px);
}

.recommended-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12px;
}

.recommended-icon {
  width: 48px;
  height: 48px;
  border-radius: 10px;
  background: linear-gradient(135deg, #fbbf24, #f59e0b);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 20px;
}

.recommended-body {
  margin-bottom: 16px;
}

.recommended-title {
  font-size: 16px;
  font-weight: 600;
  color: #111827;
  margin: 0 0 8px;
}

.recommended-desc {
  font-size: 13px;
  color: #6b7280;
  line-height: 1.5;
  margin: 0;
}

.recommended-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 12px;
  border-top: 1px solid #e5e7eb;
}

.recommended-meta {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 12px;
  color: #6b7280;
}

.btn-link-small {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-size: 13px;
  color: #f59e0b;
  text-decoration: none;
  font-weight: 500;
}

.btn-link-small:hover {
  text-decoration: underline;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 20px;
  text-align: center;
}

.empty-state svg {
  color: #9ca3af;
  margin-bottom: 16px;
}

.empty-state p {
  font-size: 14px;
  color: #6b7280;
  margin: 0 0 4px;
}

.empty-hint {
  font-size: 12px !important;
  color: #9ca3af !important;
}

.table-footer {
  padding: 16px 24px;
  background: #f9fafb;
  border-top: 1px solid #e5e7eb;
}

.table-info {
  font-size: 13px;
  color: #6b7280;
}

.form-card {
  background: white;
  border-radius: 12px;
  border: 1px solid #e5e7eb;
  overflow: hidden;
}

.form-header {
  padding: 20px;
  background: linear-gradient(135deg, #fbbf24, #f59e0b);
  color: white;
}

.form-header-content {
  display: flex;
  align-items: center;
  gap: 12px;
}

.form-icon {
  width: 40px;
  height: 40px;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.form-title {
  font-size: 16px;
  font-weight: 600;
  margin: 0 0 4px;
}

.form-description {
  font-size: 13px;
  opacity: 0.9;
  margin: 0;
}

.form-body {
  padding: 24px;
}

.form-group {
  margin-bottom: 20px;
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 13px;
  font-weight: 500;
  color: #374151;
  margin-bottom: 8px;
}

.form-input-wrapper {
  position: relative;
}

.form-input-icon {
  position: absolute;
  left: 12px;
  top: 50%;
  transform: translateY(-50%);
  color: #9ca3af;
  pointer-events: none;
}

.form-input {
  width: 100%;
  padding: 10px 12px 10px 38px;
  border: 1px solid #e5e7eb;
  border-radius: 6px;
  font-size: 13px;
  color: #111827;
  background: white;
  transition: all 0.2s;
}

.form-input:focus {
  outline: none;
  border-color: #f59e0b;
  box-shadow: 0 0 0 3px rgba(245, 158, 11, 0.1);
}

.form-input::placeholder {
  color: #9ca3af;
}

.form-textarea {
  width: 100%;
  padding: 10px;
  border: 1px solid #e5e7eb;
  border-radius: 6px;
  font-size: 13px;
  color: #111827;
  background: white;
  resize: vertical;
  min-height: 70px;
  transition: all 0.2s;
  font-family: inherit;
}

.form-textarea:focus {
  outline: none;
  border-color: #f59e0b;
  box-shadow: 0 0 0 3px rgba(245, 158, 11, 0.1);
}

.form-textarea::placeholder {
  color: #9ca3af;
}

.form-hint {
  margin-top: 6px;
  font-size: 12px;
  color: #6b7280;
}

.form-actions {
  display: flex;
  justify-content: flex-end;
  gap: 12px;
  padding-top: 20px;
  border-top: 1px solid #e5e7eb;
  margin-top: 24px;
}

.btn-submit {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 8px 16px;
  background: #f59e0b;
  color: white;
  border: none;
  border-radius: 6px;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s;
}

.btn-submit:hover {
  background: #d97706;
  transform: translateY(-1px);
  box-shadow: 0 4px 12px rgba(245, 158, 11, 0.2);
}

.info-card {
  background: white;
  border-radius: 10px;
  border: 1px solid #e5e7eb;
  overflow: hidden;
}

.info-card-header {
  padding: 16px 20px;
  background: #f9fafb;
  border-bottom: 1px solid #e5e7eb;
}

.info-card-title {
  font-size: 14px;
  font-weight: 600;
  color: #111827;
  margin: 0;
}

.info-card-body {
  padding: 20px;
}

.tips-list {
  list-style: none;
  padding: 0;
  margin: 0;
}

.tips-list li {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  padding: 8px 0;
  font-size: 13px;
  color: #4b5563;
  line-height: 1.5;
}

.tips-list li svg {
  color: #10b981;
  flex-shrink: 0;
  margin-top: 1px;
}

@media (max-width: 1024px) {
  .content-grid {
    grid-template-columns: 1fr;
  }
  
  .recommended-grid {
    grid-template-columns: 1fr;
  }
}
</style>

<script>
// 修改每页显示数量
function changePerPage(perPage) {
  const url = new URL(window.location.href);
  url.searchParams.set('per_page', perPage);
  url.searchParams.delete('page');
  window.location.href = url.toString();
}
</script>

<style>
/* 分页组件样式 */
.table-footer {
  display: flex !important;
  align-items: center !important;
  justify-content: space-between !important;
  gap: 16px !important;
  flex-wrap: wrap !important;
}

.table-per-page {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  color: #374151;
}

.per-page-select {
  padding: 6px 10px;
  border: 1px solid #e5e7eb;
  border-radius: 6px;
  font-size: 13px;
  background: white;
  color: #374151;
  cursor: pointer;
}

.per-page-select:focus {
  outline: none;
  border-color: #f59e0b;
  box-shadow: 0 0 0 3px rgba(245, 158, 11, 0.1);
}

.pagination-nav {
  display: flex;
  align-items: center;
  gap: 4px;
}

.pagination-item {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 32px;
  height: 32px;
  padding: 0 8px;
  border: 1px solid #e5e7eb;
  border-radius: 6px;
  font-size: 13px;
  color: #374151;
  text-decoration: none;
  transition: all 0.2s;
  background: white;
}

.pagination-item:hover:not(.pagination-disabled) {
  background: #f3f4f6;
  border-color: #d1d5db;
}

.pagination-item.pagination-active {
  background: #f59e0b;
  color: white;
  border-color: #f59e0b;
}

.pagination-item.pagination-disabled {
  opacity: 0.5;
  cursor: not-allowed;
  pointer-events: none;
}

.pagination-ellipsis {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 32px;
  height: 32px;
  color: #9ca3af;
  font-size: 13px;
}

@media (max-width: 768px) {
  .table-footer {
    flex-direction: column !important;
    align-items: flex-start !important;
  }
  
  .pagination-nav {
    width: 100%;
    overflow-x: auto;
    flex-wrap: wrap;
  }
}
</style>
