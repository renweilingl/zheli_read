<div class="layui-tab">

  <div class="x-nav">
    <span class="layui-breadcrumb">
      <%= link_to "图书管理", :admin_picture_books %>
      <a><cite>新增单本 <span><<<%= @book.name %>>></span></cite></a>
    </span>
    <%= render 'common/user_info' %>
  </div>

  <div class="x-body">
    <%= form_for(@chapter, url: :add_chapter_admin_picture_book, method: :post, :html => {:class => "layui-form"}) do |f| %>
      <%= f.hidden_field :book_id %>

      <div class="layui-form-item">
        <label class="layui-form-label">标题</label>
        <div class="layui-input-block">
          <%= f.text_field :name, class: "layui-input" %>
        </div>
      </div>

      <% if false %>
      <div class="layui-form-item">
        <label class="layui-form-label">序号</label>
        <div class="layui-input-block">
          <%= f.number_field :sn, class: "layui-input", min: 1, step: 1, required: true %>
        </div>
      </div>
      <% end %>

      <div class="layui-form-item">
        <label class="layui-form-label">状态</label>
        <div class="layui-input-block">
          <%= f.radio_button :is_published, true, title: "上线" %>
          <%= f.radio_button :is_published, false, title: "下线" %>
        </div>
      </div>

      <div class="layui-form-item">
        <label class="layui-form-label">是否免费</label>
        <div class="layui-input-block">
          <%= f.radio_button :is_free, true, title: "免费" %>
          <%= f.radio_button :is_free, false, title: "付费" %>
        </div>
      </div>

      <div class="layui-form-item">                                                  
        <%= f.label :cover_image_url, class: "layui-form-label" do %>                
          <span class="required">*</span> 内容封面
        <% end %>                                                                    
        <div class="layui-input-block">
          <div class="layui-upload">                                                 
            <button type="button" class="layui-btn layui-btn-normal" id="upload-cover">
              <i class="layui-icon layui-icon-upload"></i> 上传封面                  
            </button>                                                                
            <span class="upload-tip" style="margin-left: 10px; color: #999;">支持 JPG、PNG、GIF、WebP 格式，最大 5MB</span>
          </div>                                                                     
          <div id="cover-preview" style="margin-top: 10px; display: none;">          
            <img id="cover-img" src="" style="max-width: 200px; max-height: 280px; border-radius: 4px; border: 1px solid #e6e6e6;">
            <button type="button" class="layui-btn layui-btn-xs layui-btn-danger cover-remove" style="margin-left: 10px;">
              <i class="layui-icon layui-icon-close"></i> 移除                       
            </button>                                                                
          </div>                                                                     
          <%= f.hidden_field :cover_image_url, id: "cover_image_url" %>              
        </div>                                                                       
      </div> 

      <div class="layui-form-item">                                                  
        <label class="layui-form-label">内容文件</label>                             
        <div class="layui-input-block">                                              
          <div class="layui-upload-drag" id="file-upload" style="width: 100%; padding: 30px; text-align: center;">
            <i class="layui-icon layui-icon-upload" style="font-size: 48px; color: #9ca3af;"></i>
            <p style="margin-top: 15px; color: #6b7280;">点击上传，或将文件拖拽到此处</p>
            <p class="layui-word-aux" id="file-restriction" style="margin-top: 5px;">支持格式：epub、pdf、mp3、mp4</p>
          </div>                                                                     
          <div id="upload-progress" style="display: none; margin-top: 15px;">
            <div class="layui-progress" lay-filter="upload-progress">
              <div class="layui-progress-bar" lay-percent="0%"></div>
            </div>
            <div style="margin-top: 10px; text-align: center;">
              <span id="upload-status">上传中...</span>
              <span id="upload-percent">0%</span>
            </div>
          </div>

          <% if @chapter.new_record? %>                                              
            <div id="upload-result" style="display: none; margin-top: 15px;" class="layui-card">
              <div class="layui-card-body" style="padding: 15px;">                   
                <div style="display: flex; align-items: center; gap: 15px;">         
                  <i class="layui-icon layui-icon-ok-circle" style="font-size: 32px; color: #10b981;"></i>
                  <div>                                                              
                    <div id="file-name" style="font-weight: bold;"></div>            
                    <div style="display: flex; gap: 10px;">                          
                      <span id="file-type-badge" class="layui-badge"></span>         
                      <span id="file-size" class="layui-word-aux"></span>            
                    </div>                                                           
                  </div>                                                             
                  <div style="margin-left: auto;">                                   
                    <button type="button" class="layui-btn layui-btn-xs layui-btn-danger" id="remove-file">移除</button>
                  </div>                                                             
                </div>                                                               
              </div>                                                                 
            </div>                                                                   
          <% else %> 
            <div id="upload-result" class="layui-card" style="display: inline-block; padding: 15px;"> 
              <div style="display: flex; align-items: center; gap: 15px;">           
                <div style="width: 40px; height: 40px; background-color: <%= @content.file_type_color %>20; border-radius: 4px; display: flex; align-items: center; justify-content: center;">
                      <i class="layui-icon <%= @content.file_type_icon %>" style="color: <%= @content.file_type_color %>; font-size: 20px;"></i>
                </div>                                                               
                <div>                                                                
                  <div id="file-name" style="font-weight: bold;"></div>              
                  <div id="file-type-badge" style="font-weight: bold;"><%= @content.file_name %></div>  
                  <div id="file-size" class="layui-word-aux"><%= @content.file_size_desc %></div> 
                </div>                                                               
                <div style="margin-left: auto;">                                     
                  <button type="button" class="layui-btn layui-btn-xs layui-btn-danger" id="remove-file">移除</button>
                </div>                                                               
              </div>                                                                 
            </div>                                                                   
          <% end %> 
        </div>

        <%= f.hidden_field :content_file_url, id: "file-url-hidden" %>
        <%= f.hidden_field :content_file_name, id: "file-name-hidden" %>
        <%= f.hidden_field :content_file_type, id: "file-type-hidden" %>
      </div>

      <div class="layui-form-item" style="padding-bottom: 100px;">
        <div class="layui-input-block">
          <button class="layui-btn layui-bg-wgreen" lay-submit lay-filter="component-form-element">提交保存</button>
          <%= link_to "取消", chapters_admin_picture_book_path(@book), class: "layui-btn layui-btn-primary" %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<script>
  layui.use(['form', 'upload', 'layer'], function(){
    var form = layui.form,
        laydate = layui.laydate,
        upload = layui.upload,
        layer = layui.layer,
        $ = layui.$;

        form.render();

        upload.render({
          elem: '#upload-cover',
          url: '<%= upload_img_files_path %>',
          accept: 'images',
          exts: 'jpg|jpeg|png|gif|webp',
          size: 5 * 1024,
          done: function(res){
            if(res.success){
              $('#cover_image_url').val(res.url);
              $('#cover-img').attr('src', res.preivew_url);
              $('#cover-preview').show();
              layer.msg('上传成功');
            } else {
              layer.msg(res.message || '上传失败', {icon: 2});
            }
          },
          error: function(){
            layer.msg('上传失败', {icon: 2});
          }
        });

        // 文件上传
        var uploadInst = upload.render({
          elem: '#file-upload',
          url: '<%= upload_files_path %>',
          auto: true,
          accept: 'file',
          size: 204800, // 200MB
          before: function(obj){
          // 显示进度条
            $('#upload-progress').show();
            $('#upload-result').hide();
            element.progress('upload-progress', '0%');
            $('#upload-percent').text('0%');
            $('#upload-status').text('上传中...');
          },
          progress: function(n, elem){
            element.progress('upload-progress', n + '%');
            $('#upload-percent').text(n + '%');
          },
          done: function(res){                                                       
            if (res.code === 0) {                                                    
              $('#upload-progress').hide();                                          
              $('#upload-result').show();                                            
              $('#file-name').text(res.data.file_name);                              
              $('#file-size').text(res.data.file_size);                              
              $('#file-url-hidden').val(res.data.file_url);
              $('#file-name-hidden').val(res.data.file_name);
              //$('#file-size-hidden').val(res.data.file_size);
              $('#file-type-hidden').val(res.data.file_type);
              var fileTypeColors = {                                                 
                'epub': '#10b981',                                                   
                'pdf': '#ef4444',                                                    
                'mp3': '#8b5cf6',                                                    
                'mp4': '#3b82f6'                                                     
              };                                                                     
              var fileType = res.data.file_type || '';                               
              $('#file-type-badge').text(res.data.file_type_name || fileType.toUpperCase());
              if (fileTypeColors[fileType]) {                                        
                $('#file-type-badge').css('background-color', fileTypeColors[fileType]);
              }                                                                      
                                                                                 
              layer.msg('上传成功', {icon: 6});                                      
            } else {                                                                 
              layer.msg(res.msg || '上传失败', {icon: 5});                           
              $('#upload-progress').hide();                                          
            }                                                                        
          }, 
          error: function(){                                                         
            layer.msg('上传失败，请重试', {icon: 5});                                
            $('#upload-progress').hide();                                            
          }                                                                          
        }); 
  })
</script>
