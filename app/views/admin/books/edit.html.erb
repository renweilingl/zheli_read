<% content_for :title, "编辑绘本" %>

<div class="page-header">
  <h1 class="page-title">编辑绘本</h1>
  <div class="page-actions">
    <%= link_to admin_books_path, class: "layui-btn layui-btn-primary" do %>
      <i class="layui-icon layui-icon-return"></i> 返回列表
    <% end %>
    <%= link_to admin_book_path(@book), class: "layui-btn layui-btn-normal" do %>
      <i class="layui-icon layui-icon-about"></i> 查看详情
    <% end %>
  </div>
</div>

<div class="layui-card">
  <div class="layui-card-body" style="padding: 30px;">
    <%= form_with(model: [:admin, @book], local: true, class: "layui-form", id: "book-form") do |f| %>

      <!-- 核心基础信息 -->
      <fieldset class="layui-elem-field layui-field-title">
        <legend><i class="layui-icon layui-icon-note"></i> 核心基础信息</legend>
      </fieldset>

      <div class="layui-form-item">
        <%= f.label :name, class: "layui-form-label" do %>
          <span class="required">*</span> 绘本名称
        <% end %>
        <div class="layui-input-block">
          <%= f.text_field :name, class: "layui-input", placeholder: "请输入绘本名称", maxlength: 100, required: true, style: "width: 500px;", disabled: @book.locked? %>
        </div>
      </div>

      <div class="layui-form-item">
        <%= f.label :cover_image_url, class: "layui-form-label" do %>
          <span class="required">*</span> 绘本封面
        <% end %>
        <div class="layui-input-block">
          <% if @book.cover_image_url.present? %>
            <div id="cover-preview">
              <img id="cover-img" src="<%= @book.cover_image_url %>" style="max-width: 200px; max-height: 280px; border-radius: 4px; border: 1px solid #e6e6e6;">
              <% unless @book.locked? %>
                <button type="button" class="layui-btn layui-btn-xs layui-btn-danger cover-remove" style="margin-left: 10px;">
                  <i class="layui-icon layui-icon-close"></i> 移除
                </button>
              <% end %>
            </div>
          <% else %>
            <div class="layui-upload">
              <button type="button" class="layui-btn layui-btn-normal" id="upload-cover">
                <i class="layui-icon layui-icon-upload"></i> 上传封面
              </button>
            </div>
          <% end %>
          <div id="cover-upload" style="margin-top: 10px; <%= 'display:none' if @book.cover_image_url.present? %>">
            <div class="layui-upload">
              <button type="button" class="layui-btn layui-btn-normal" id="upload-cover-new">
                <i class="layui-icon layui-icon-upload"></i> 上传封面
              </button>
              <span class="upload-tip" style="margin-left: 10px; color: #999;">支持 JPG、PNG、GIF、WebP 格式，最大 5MB</span>
            </div>
          </div>
          <%= f.hidden_field :cover_image_url %>
          <%= f.hidden_field :cover_image_name %>
        </div>
      </div>

      <div class="layui-form-item">
        <%= f.label :book_type, class: "layui-form-label" do %>
          <span class="required">*</span> 绘本类型
        <% end %>
        <div class="layui-input-block">
          <%= f.select :book_type,
                options_for_select(Book::BOOK_TYPE_NAMES.map { |k, v| [v, k] }, @book.book_type),
                { include_blank: '请选择绘本类型' },
                { class: "layui-input", required: true, style: "width: 200px;", disabled: @book.locked? } %>
        </div>
      </div>

      <div class="layui-form-item">
        <%= f.label :age_range, class: "layui-form-label" do %>
          <span class="required">*</span> 年龄范围
        <% end %>
        <div class="layui-input-inline" style="width: 100px;">
          <%= f.number_field :min_age, class: "layui-input", placeholder: "最小", min: 0, value: @book.min_age || 0, disabled: @book.locked? %>
        </div>
        <div class="layui-form-mid" style="padding: 0 10px !important;">至</div>
        <div class="layui-input-inline" style="width: 100px;">
          <%= f.number_field :max_age, class: "layui-input", placeholder: "最大", min: 0, value: @book.max_age || 99, disabled: @book.locked? %>
        </div>
        <div class="layui-form-mid" style="padding: 0 !important;">岁</div>
      </div>

      <div class="layui-form-item">
        <%= f.label :recommended_age, class: "layui-form-label" do %>
          <span class="required">*</span> 最佳年龄推荐
        <% end %>
        <div class="layui-input-block">
          <%= f.text_field :recommended_age, class: "layui-input", placeholder: "如：3-6", maxlength: 20, required: true, style: "width: 200px;", disabled: @book.locked? %>
        </div>
      </div>

      <div class="layui-form-item">
        <%= f.label :categories, class: "layui-form-label" do %>
          <span class="required">*</span> 分类
        <% end %>
        <div class="layui-input-block">
          <div id="category-tags" class="tag-container" style="min-height: 38px; border: 1px solid #e6e6e6; border-radius: 2px; padding: 5px 10px; background: #fff;">
            <% @book.categories_array.each do |cat| %>
              <span class="tag-item"><%= cat %><i class="layui-icon layui-icon-close tag-remove" data-value="<%= cat %>"></i></span>
            <% end %>
          </div>
          <%= f.hidden_field :categories, id: "categories-input", value: @book.categories_array.join(',') %>
          <input type="text" id="category-input" class="layui-input" placeholder="输入分类后按回车添加" style="width: 200px; margin-top: 10px;" <%= 'disabled' if @book.locked? %> />
        </div>
      </div>

      <div class="layui-form-item">
        <%= f.label :themes, class: "layui-form-label" do %>
          <span class="required">*</span> 主题
        <% end %>
        <div class="layui-input-block">
          <div class="theme-checkboxes">
            <% Book::THEME_NAMES.each do |key, name| %>
              <input type="checkbox" name="book[themes][]" value="<%= key %>" title="<%= name %>"
                <%= 'checked' if @book.themes_array.include?(key.to_s) %>
                <%= 'disabled' if @book.locked? %>
                lay-skin="primary">
            <% end %>
          </div>
          <%= f.hidden_field :themes, id: "themes-input", value: @book.themes_array.join(',') %>
        </div>
      </div>

      <div class="layui-form-item">
        <%= f.label :supplier_id, class: "layui-form-label" do %>
          <span class="required">*</span> 归属供应商
        <% end %>
        <div class="layui-input-block">
          <%= f.select :supplier_id,
                options_from_collection_for_select(@suppliers, :id, :name, @book.supplier_id),
                { include_blank: '请选择供应商' },
                { class: "layui-input", style: "width: 250px;", disabled: @book.locked? } %>
        </div>
      </div>

      <!-- 版权与出版信息 -->
      <fieldset class="layui-elem-field layui-field-title">
        <legend><i class="layui-icon layui-icon-rmb"></i> 版权与出版信息</legend>
      </fieldset>

      <div class="layui-form-item">
        <%= f.label :has_copyright, "是否有版权", class: "layui-form-label" %>
        <div class="layui-input-block">
          <%= f.select :has_copyright,
                options_for_select([['否', false], ['是', true]], @book.has_copyright),
                { include_blank: '请选择' },
                { class: "layui-input", style: "width: 150px;", disabled: @book.locked? } %>
        </div>
      </div>

      <div class="layui-form-item">
        <%= f.label :payment_type, "付费类型", class: "layui-form-label" %>
        <div class="layui-input-block">
          <%= f.select :payment_type,
                options_for_select([['免费', 'free'], ['付费', 'paid'], ['会员专享', 'vip']], @book.payment_type),
                { include_blank: '请选择付费类型' },
                { class: "layui-input", style: "width: 150px;", disabled: @book.locked? } %>
        </div>
      </div>

      <div class="layui-form-item">
        <%= f.label :price, "单价", class: "layui-form-label" %>
        <div class="layui-input-inline" style="width: 120px;">
          <%= f.number_field :price, class: "layui-input", placeholder: "0.00", min: 0, step: 0.01, disabled: @book.locked? %>
        </div>
        <div class="layui-form-mid" style="padding: 0 !important;">元</div>
      </div>

      <div class="layui-form-item">
        <label class="layui-form-label">版权时间</label>
        <div class="layui-input-block layui-form-readonly">
          <span style="color: #666;"><%= @book.copyright_period %></span>
        </div>
      </div>

      <div class="layui-form-item">
        <label class="layui-form-label">ISBN号</label>
        <div class="layui-input-block layui-form-readonly">
          <span style="color: #666;"><%= @book.isbn.presence || '无' %></span>
        </div>
      </div>

      <div class="layui-form-item">
        <label class="layui-form-label">出版社</label>
        <div class="layui-input-block layui-form-readonly">
          <span style="color: #666;"><%= @book.publisher.presence || '无' %></span>
        </div>
      </div>

      <!-- 合辑与关联属性 -->
      <fieldset class="layui-elem-field layui-field-title">
        <legend><i class="layui-icon layui-icon-link"></i> 合辑与关联属性</legend>
      </fieldset>

      <div class="layui-form-item">
        <%= f.label :collections, "归属合辑", class: "layui-form-label" %>
        <div class="layui-input-block">
          <div id="collection-tags" class="tag-container" style="min-height: 38px; border: 1px solid #e6e6e6; border-radius: 2px; padding: 5px 10px; background: #fff;">
            <% @book.collections_array.each do |col| %>
              <span class="tag-item"><%= col %><i class="layui-icon layui-icon-close tag-remove" data-value="<%= col %>"></i></span>
            <% end %>
          </div>
          <%= f.hidden_field :collections, id: "collections-input", value: @book.collections_array.join(',') %>
          <input type="text" id="collection-input" class="layui-input" placeholder="输入合辑名称后按回车添加" style="width: 250px; margin-top: 10px;" <%= 'disabled' if @book.locked? %> />
        </div>
      </div>

      <div class="layui-form-item">
        <%= f.label :has_isbn, "是否存在ISBN", class: "layui-form-label" %>
        <div class="layui-input-block">
          <%= f.select :has_isbn,
                options_for_select([['否', false], ['是', true]], @book.has_isbn),
                { include_blank: '请选择' },
                { class: "layui-input", style: "width: 150px;", disabled: @book.locked? } %>
        </div>
      </div>

      <!-- 作者/译者信息 -->
      <fieldset class="layui-elem-field layui-field-title">
        <legend><i class="layui-icon layui-icon-user"></i> 作者/译者信息</legend>
      </fieldset>

      <div class="layui-form-item">
        <%= f.label :author, "作者", class: "layui-form-label" %>
        <div class="layui-input-block">
          <%= f.text_field :author, class: "layui-input", placeholder: "请输入作者", maxlength: 100, style: "width: 250px;", disabled: @book.locked? %>
        </div>
      </div>

      <div class="layui-form-item">
        <%= f.label :translator, "译者", class: "layui-form-label" %>
        <div class="layui-input-block">
          <%= f.text_field :translator, class: "layui-input", placeholder: "请输入译者", maxlength: 100, style: "width: 250px;", disabled: @book.locked? %>
        </div>
      </div>

      <div class="layui-form-item">
        <%= f.label :compiler, "编著", class: "layui-form-label" %>
        <div class="layui-input-block">
          <%= f.text_field :compiler, class: "layui-input", placeholder: "请输入编著者", maxlength: 100, style: "width: 250px;", disabled: @book.locked? %>
        </div>
      </div>

      <div class="layui-form-item">
        <%= f.label :illustrator, "编绘", class: "layui-form-label" %>
        <div class="layui-input-block">
          <%= f.text_field :illustrator, class: "layui-input", placeholder: "请输入编绘者", maxlength: 100, style: "width: 250px;", disabled: @book.locked? %>
        </div>
      </div>

      <div class="layui-form-item">
        <%= f.label :editor_in_chief, "主编", class: "layui-form-label" %>
        <div class="layui-input-block">
          <%= f.text_field :editor_in_chief, class: "layui-input", placeholder: "请输入主编", maxlength: 100, style: "width: 250px;", disabled: @book.locked? %>
        </div>
      </div>

      <div class="layui-form-item">
        <%= f.label :awards, "关联奖项", class: "layui-form-label" %>
        <div class="layui-input-block">
          <div id="award-tags" class="tag-container" style="min-height: 38px; border: 1px solid #e6e6e6; border-radius: 2px; padding: 5px 10px; background: #fff;">
            <% @book.awards_array.each do |award| %>
              <span class="tag-item"><%= award %><i class="layui-icon layui-icon-close tag-remove" data-value="<%= award %>"></i></span>
            <% end %>
          </div>
          <%= f.hidden_field :awards, id: "awards-input", value: @book.awards_array.join(',') %>
          <input type="text" id="award-input" class="layui-input" placeholder="输入奖项名称后按回车添加" style="width: 250px; margin-top: 10px;" <%= 'disabled' if @book.locked? %> />
        </div>
      </div>

      <!-- 内容与展示信息 -->
      <fieldset class="layui-elem-field layui-field-title">
        <legend><i class="layui-icon layui-icon-picture"></i> 内容与展示信息</legend>
      </fieldset>

      <div class="layui-form-item">
        <%= f.label :intro_image_url, "图片简介", class: "layui-form-label" %>
        <div class="layui-input-block">
          <% if @book.intro_image_url.present? %>
            <div id="intro-preview">
              <img id="intro-img" src="<%= @book.intro_image_url %>" style="max-width: 300px; max-height: 400px; border-radius: 4px; border: 1px solid #e6e6e6;">
              <% unless @book.locked? %>
                <button type="button" class="layui-btn layui-btn-xs layui-btn-danger intro-remove" style="margin-left: 10px;">
                  <i class="layui-icon layui-icon-close"></i> 移除
                </button>
              <% end %>
            </div>
          <% else %>
            <div class="layui-upload">
              <button type="button" class="layui-btn layui-btn-normal" id="upload-intro">
                <i class="layui-icon layui-icon-upload"></i> 上传图片简介
              </button>
            </div>
          <% end %>
          <div id="intro-upload" style="margin-top: 10px; <%= 'display:none' if @book.intro_image_url.present? %>">
            <div class="layui-upload">
              <button type="button" class="layui-btn layui-btn-normal" id="upload-intro-new">
                <i class="layui-icon layui-icon-upload"></i> 上传图片简介
              </button>
            </div>
          </div>
          <%= f.hidden_field :intro_image_url %>
          <%= f.hidden_field :intro_image_name %>
        </div>
      </div>

      <div class="layui-form-item">
        <%= f.label :quote_current_owner, "是否引用当前所属主", class: "layui-form-label" %>
        <div class="layui-input-block">
          <%= f.select :quote_current_owner,
                options_for_select([['否', false], ['是', true]], @book.quote_current_owner),
                { include_blank: '请选择' },
                { class: "layui-input", style: "width: 150px;", disabled: @book.locked? } %>
        </div>
      </div>

      <div class="layui-form-item">
        <%= f.label :image_description, "图片文字(app不展示)", class: "layui-form-label" %>
        <div class="layui-input-block">
          <%= f.text_area :image_description, class: "layui-textarea", placeholder: "图片说明文字，该内容不在APP端展示", rows: 3, style: "width: 500px;", disabled: @book.locked? %>
        </div>
      </div>

      <div class="layui-form-item">
        <%= f.label :description, "内容简介", class: "layui-form-label" %>
        <div class="layui-input-block">
          <%= f.text_area :description, class: "layui-textarea", placeholder: "请输入绘本的内容简介", rows: 5, style: "width: 100%;", disabled: @book.locked? %>
        </div>
      </div>

      <div class="layui-form-item">
        <%= f.label :orientation, "横屏/竖屏", class: "layui-form-label" %>
        <div class="layui-input-block">
          <%= f.select :orientation,
                options_for_select([['竖屏', 'portrait'], ['横屏', 'landscape']], @book.orientation),
                { include_blank: '请选择' },
                { class: "layui-input", style: "width: 150px;", disabled: @book.locked? } %>
        </div>
      </div>

      <div class="layui-form-item">
        <%= f.label :purchasable, "是否可购买", class: "layui-form-label" %>
        <div class="layui-input-block">
          <%= f.select :purchasable,
                options_for_select([['是', true], ['否', false]], @book.purchasable),
                { include_blank: '请选择' },
                { class: "layui-input", style: "width: 150px;", disabled: @book.locked? } %>
        </div>
      </div>

      <div class="layui-form-item">
        <%= f.label :editor_recommendation, "编辑推荐语", class: "layui-form-label" %>
        <div class="layui-input-block">
          <%= f.text_field :editor_recommendation, class: "layui-input", placeholder: "请输入编辑推荐语", maxlength: 200, style: "width: 500px;", disabled: @book.locked? %>
        </div>
      </div>

      <div class="layui-form-item">
        <%= f.label :detail_recommendation, "详情页推荐语", class: "layui-form-label" %>
        <div class="layui-input-block">
          <%= f.text_field :detail_recommendation, class: "layui-input", placeholder: "请输入详情页推荐语", maxlength: 200, style: "width: 500px;", disabled: @book.locked? %>
        </div>
      </div>

      <div class="layui-form-item">
        <%= f.label :page_count, "页数", class: "layui-form-label" %>
        <div class="layui-input-block">
          <%= f.number_field :page_count, class: "layui-input", placeholder: "请输入总页数", min: 0, style: "width: 150px;", disabled: @book.locked? %>
        </div>
      </div>

      <div class="layui-form-item">
        <%= f.label :full_trial_read, "是否整本试读", class: "layui-form-label" %>
        <div class="layui-input-block">
          <%= f.select :full_trial_read,
                options_for_select([['否', false], ['是', true]], @book.full_trial_read),
                { include_blank: '请选择' },
                { class: "layui-input", style: "width: 150px;", disabled: @book.locked? } %>
        </div>
      </div>

      <div class="layui-form-item">
        <%= f.label :trial_page_count, "试读页数", class: "layui-form-label" %>
        <div class="layui-input-block">
          <%= f.number_field :trial_page_count, class: "layui-input", placeholder: "请输入试读页数", min: 0, style: "width: 150px;", disabled: @book.locked? %>
        </div>
      </div>

      <div class="layui-form-item">
        <%= f.label :word_count, "字数", class: "layui-form-label" %>
        <div class="layui-input-block">
          <%= f.number_field :word_count, class: "layui-input", placeholder: "请输入总字数", min: 0, style: "width: 150px;", disabled: @book.locked? %>
        </div>
      </div>

      <div class="layui-form-item">
        <%= f.label :remark, "备注", class: "layui-form-label" %>
        <div class="layui-input-block">
          <%= f.text_area :remark, class: "layui-textarea", placeholder: "请输入备注信息", rows: 3, style: "width: 500px;", disabled: @book.locked? %>
        </div>
      </div>

      <!-- 状态与数据设置 -->
      <fieldset class="layui-elem-field layui-field-title">
        <legend><i class="layui-icon layui-icon-set"></i> 状态与数据设置</legend>
      </fieldset>

      <div class="layui-form-item">
        <%= f.label :scheduled_online_at, "定时上线", class: "layui-form-label" %>
        <div class="layui-input-block">
          <%= f.text_field :scheduled_online_at, class: "layui-input", id: "scheduled_online_at", placeholder: "请选择定时上线时间", value: @book.scheduled_online_at.try(:strftime, "%Y-%m-%d %H:%M:%S"), style: "width: 200px;" %>
        </div>
      </div>

      <div class="layui-form-item">
        <%= f.label :locked, "锁定", class: "layui-form-label" %>
        <div class="layui-input-block">
          <%= f.select :locked,
                options_for_select([['否', false], ['是', true]], @book.locked),
                { include_blank: '请选择' },
                { class: "layui-input", style: "width: 150px;" } %>
        </div>
      </div>

      <div class="layui-form-item">
        <%= f.label :base_read_count, "基础阅读人数", class: "layui-form-label" %>
        <div class="layui-input-block">
          <%= f.number_field :base_read_count, class: "layui-input", placeholder: "0", min: 0, style: "width: 150px;" %>
        </div>
      </div>

      <div class="layui-form-item">
        <%= f.label :base_rating_count, "基础评分人数", class: "layui-form-label" %>
        <div class="layui-input-block">
          <%= f.number_field :base_rating_count, class: "layui-input", placeholder: "0", min: 0, style: "width: 150px;" %>
        </div>
      </div>

      <div class="layui-form-item">
        <%= f.label :base_rating, "基础评分", class: "layui-form-label" %>
        <div class="layui-input-inline" style="width: 100px;">
          <%= f.number_field :base_rating, class: "layui-input", placeholder: "4.8", min: 0, max: 5, step: 0.1 %>
        </div>
        <div class="layui-form-mid" style="padding: 0 !important;">分</div>
      </div>

      <!-- 标签系统 -->
      <fieldset class="layui-elem-field layui-field-title">
        <legend><i class="layui-icon layui-icon-tag"></i> 标签系统</legend>
      </fieldset>

      <div class="layui-form-item">
        <label class="layui-form-label">一级标签</label>
        <div class="layui-input-block">
          <div id="level1-tags" class="tag-container" style="min-height: 38px; border: 1px solid #e6e6e6; border-radius: 2px; padding: 5px 10px; background: #fff;">
            <% @book.level_one_tags_array.each do |tag| %>
              <span class="tag-item"><%= tag %><i class="layui-icon layui-icon-close tag-remove" data-value="<%= tag %>" data-type="level1"></i></span>
            <% end %>
          </div>
          <%= f.hidden_field :level_one_tags, id: "level1-input", value: @book.level_one_tags_array.join(',') %>
          <input type="text" id="level1-input-text" class="layui-input" placeholder="输入一级标签后按回车添加" style="width: 200px; margin-top: 10px;" />
        </div>
      </div>

      <div class="layui-form-item">
        <label class="layui-form-label">二级标签</label>
        <div class="layui-input-block">
          <div id="level2-tags" class="tag-container" style="min-height: 38px; border: 1px solid #e6e6e6; border-radius: 2px; padding: 5px 10px; background: #fff;">
            <% @book.level_two_tags_array.each do |tag| %>
              <span class="tag-item"><%= tag %><i class="layui-icon layui-icon-close tag-remove" data-value="<%= tag %>" data-type="level2"></i></span>
            <% end %>
          </div>
          <%= f.hidden_field :level_two_tags, id: "level2-input", value: @book.level_two_tags_array.join(',') %>
          <input type="text" id="level2-input-text" class="layui-input" placeholder="输入二级标签后按回车添加" style="width: 200px; margin-top: 10px;" />
        </div>
      </div>

      <!-- 提交按钮 -->
      <div class="layui-form-item" style="margin-top: 30px;">
        <div class="layui-input-block">
          <button type="submit" class="layui-btn layui-btn-normal" lay-submit lay-filter="submit-form" <%= 'disabled' if @book.locked? %>>
            <i class="layui-icon layui-icon-release"></i> 保存修改
          </button>
          <% unless @book.locked? %>
            <button type="reset" class="layui-btn layui-btn-primary">重置</button>
          <% end %>
          <%= link_to "取消", admin_books_path, class: "layui-btn layui-btn-primary" %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<style>
  .layui-elem-field {
    margin-top: 30px;
  }

  .layui-elem-field legend {
    font-size: 16px;
    color: #52c41a;
  }

  .required {
    color: #ff4d4f;
    margin-right: 2px;
  }

  .tag-container {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .tag-item {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 4px 10px;
    background: #f0f9eb;
    border: 1px solid #c2e7b0;
    border-radius: 4px;
    color: #52c41a;
    font-size: 13px;
  }

  .tag-item .tag-remove {
    cursor: pointer;
    font-size: 14px;
    color: #52c41a;
  }

  .tag-item .tag-remove:hover {
    color: #ff4d4f;
  }

  .theme-checkboxes {
    display: flex;
    flex-wrap: wrap;
    gap: 15px;
  }

  .layui-form-readonly {
    padding-top: 9px;
  }

  .upload-tip {
    font-size: 12px;
    color: #999;
  }
</style>

<script>
  layui.use(['form', 'laydate', 'upload', 'layer'], function(){
    var form = layui.form,
        laydate = layui.laydate,
        upload = layui.upload,
        layer = layui.layer,
        $ = layui.$;

    form.render();

    // 日期时间选择器
    laydate.render({
      elem: '#scheduled_online_at',
      type: 'datetime',
      format: 'yyyy-MM-dd HH:mm:ss'
    });

    // 封面上传
    upload.render({
      elem: '#upload-cover-new',
      url: '<%= upload_cover_admin_books_path %>',
      accept: 'images',
      exts: 'jpg|jpeg|png|gif|webp',
      size: 5 * 1024,
      done: function(res){
        if(res.success){
          $('#cover_image_url').val(res.url);
          $('#cover_image_name').val(res.name);
          $('#cover-upload').hide();
          $('#cover-preview').show();
          $('#cover-img').attr('src', res.url);
          layer.msg('上传成功');
        } else {
          layer.msg(res.message || '上传失败', {icon: 2});
        }
      },
      error: function(){
        layer.msg('上传失败', {icon: 2});
      }
    });

    $('.cover-remove').on('click', function(){
      $('#cover_image_url').val('');
      $('#cover_image_name').val('');
      $('#cover-preview').hide();
      $('#cover-upload').show();
    });

    // 图片简介上传
    upload.render({
      elem: '#upload-intro-new',
      url: '<%= upload_intro_image_admin_books_path %>',
      accept: 'images',
      exts: 'jpg|jpeg|png|gif|webp',
      size: 5 * 1024,
      done: function(res){
        if(res.success){
          $('#intro_image_url').val(res.url);
          $('#intro_image_name').val(res.name);
          $('#intro-upload').hide();
          $('#intro-preview').show();
          $('#intro-img').attr('src', res.url);
          layer.msg('上传成功');
        } else {
          layer.msg(res.message || '上传失败', {icon: 2});
        }
      },
      error: function(){
        layer.msg('上传失败', {icon: 2});
      }
    });

    $('.intro-remove').on('click', function(){
      $('#intro_image_url').val('');
      $('#intro_image_name').val('');
      $('#intro-preview').hide();
      $('#intro-upload').show();
    });

    // 通用标签处理函数
    function initTagInput(containerId, inputId, hiddenId) {
      var tags = [];
      if(containerId === 'category-tags') tags = <%= raw @book.categories_array.to_json %>;
      if(containerId === 'collection-tags') tags = <%= raw @book.collections_array.to_json %>;
      if(containerId === 'award-tags') tags = <%= raw @book.awards_array.to_json %>;
      if(containerId === 'level1-tags') tags = <%= raw @book.level_one_tags_array.to_json %>;
      if(containerId === 'level2-tags') tags = <%= raw @book.level_two_tags_array.to_json %>;

      function render() {
        var html = '';
        tags.forEach(function(tag){
          html += '<span class="tag-item">' + tag + '<i class="layui-icon layui-icon-close tag-remove" data-value="' + tag + '"></i></span>';
        });
        $('#' + containerId).html(html);
        $('#' + hiddenId).val(tags.join(','));
        bindRemove();
      }

      $('#' + inputId).on('keydown', function(e){
        if(e.keyCode === 13){
          e.preventDefault();
          var val = $(this).val().trim();
          if(val && tags.indexOf(val) === -1 && tags.length < 20){
            tags.push(val);
            render();
            $(this).val('');
          }
        }
      });

      function bindRemove() {
        $('.tag-remove').off('click').on('click', function(){
          var val = $(this).data('value');
          tags = tags.filter(function(t){ return t !== val; });
          render();
        });
      }
      bindRemove();
    }

    // 初始化各标签输入
    initTagInput('category-tags', 'category-input', 'categories-input');
    initTagInput('collection-tags', 'collection-input', 'collections-input');
    initTagInput('award-tags', 'award-input', 'awards-input');
    initTagInput('level1-tags', 'level1-input-text', 'level1-input');
    initTagInput('level2-tags', 'level2-input-text', 'level2-input');

    // 主题复选框处理
    $('.theme-checkboxes input[type="checkbox"]').on('change', function(){
      var themes = [];
      $('.theme-checkboxes input[type="checkbox"]:checked').each(function(){
        themes.push($(this).val());
      });
      $('#themes-input').val(themes.join(','));
    });

    // 表单提交验证
    form.on('submit(submit-form)', function(data){
      // 验证主题至少选一个
      if($('.theme-checkboxes input[type="checkbox"]:checked').length === 0){
        layer.msg('请至少选择一个主题', {icon: 2});
        return false;
      }
      return true;
    });
  });
</script>
