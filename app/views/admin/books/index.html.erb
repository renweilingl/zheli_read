<div class="layui-tab">
  <div class="x-nav">
    <span class="layui-breadcrumb">
      <a href="">内容管理</a>
      <a><cite>图书管理</cite></a>
    </span>
    <%= render 'common/user_info' %>
  </div>
  <div class="x-body">
    <div class="layui-row">
      <div class="layui-col-xs9">
        <%= search_form_for(@q, url: :admin_books, :html => {class: :'layui-form layui-col-md12'}) do |f| %>
          <div class="layui-input-inline">
            <%= f.text_field :name_cont, class: :'layui-input', placeholder: "名称" %>
          </div>
          <button class="layui-btn layui-bg-blue" lay-submit lay-filter="demo-table-search"><i class="layui-icon">&#xe615;</i>查询</button>
          <%= link_to "重置", :admin_books, class: "layui-btn layui-btn-primary" %>
        <% end %>
      </div>
      <div class="layui-col-3 text-right">
        <%= link_to :new_admin_book, class: 'layui-btn layui-bg-blue' do %>
          <i class="layui-icon"></i>新增图书
        <% end %>
      </div>
    </div>

    <table class="layui-table">
      <thead>
        <tr>
          <th width="60">ID</th>
          <th>图书信息</th>
          <th width="80">类型</th>
          <th width="70">付费</th>
          <th width="60">页数</th>
          <th width="60">锁定</th>
          <th width="70">状态</th>
          <th width="130">创建时间</th>
          <th width="220" style="text-align:center;">操作</th>
        </tr>
      </thead>
      <tbody>
        <% if @books.empty? %>
          <tr>
            <td colspan="10" style="text-align: center; padding: 40px 0; color: #9ca3af;">
              <i class="layui-icon layui-icon-face-cry" style="font-size: 48px;"></i>
              <div style="margin-top: 10px;">暂无图书数据</div>
            </td>
          </tr>
        <% else %>
          <% @books.each do |book| %>
            <tr>
              <td><%= book.id %></td>
              <td>
                <div style="display: flex; align-items: flex-start; gap: 10px;">
                  <% if book.cover_image_url.present? %>
                    <img src="<%= FileMap.new(book.cover_image_url, "img").secrity_src %>" style="width: 48px; height: 64px; object-fit: cover; border-radius: 4px;" />
                  <% else %>
                    <div style="width: 48px; height: 64px; background-color: #52c41a20; border-radius: 4px; display: flex; align-items: center; justify-content: center;">
                      <i class="layui-icon layui-icon-picture" style="color: #52c41a; font-size: 20px;"></i>
                    </div>
                  <% end %>
                  <div>
                    <div style="font-weight: 500; max-width: 220px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                      <%= book.name %>
                    </div>
                    <div style="font-size: 12px; color: #9ca3af;">
                      <% if book.supplier %>
                        <span><i class="layui-icon layui-icon-group"></i> <%= book.supplier.name %></span>
                      <% end %>
                    </div>
                  </div>
                </div>
              </td>
              <td><%= book.recommended_age %></td>
              <td>
                <span class="layui-badge <%= book.payment_type == "free" ? 'layui-bg-green' : (book.vip? ? 'layui-bg-purple' : 'layui-bg-red') %>">
                  <%= book.payment_type_name %>
                </span>
              </td>
              <td><%= book.page_count %>页</td>
              <td>
                <span class="layui-badge <%= book.locked? ? 'layui-bg-red' : 'layui-bg-gray' %>">
                  <%= book.locked? ? '是' : '否' %>
                </span>
              </td>
              <td>
                <span class="layui-badge <%= case book.status when 'published' then 'layui-bg-green' when 'draft' then 'layui-bg-orange' else 'layui-bg-gray' end %>">
                  <%= book.status_name %>
                </span>
              </td>
              <td><%= book.created_at.strftime("%Y-%m-%d") %></td>
              <td style="text-align:center;">
                <div class="layui-btn-group">
                  <%= link_to "详情", admin_book_path(book), class: "layui-btn layui-btn-xs" %>
                  <%= link_to "编辑", edit_admin_book_path(book), class: "layui-btn layui-btn-xs" %>
                  <% if book.draft? %>
                    <%= link_to "发布", toggle_status_admin_book_path(book), method: :put, class: "layui-btn layui-btn-xs", data: { confirm: '确认发布吗?' } %>
                  <% elsif book.published? %>
                    <%= link_to "下线", toggle_status_admin_book_path(book), method: :put, class: "layui-btn layui-btn-xs", data: { confirm: '确认下线吗?' } %>
                  <% else %>
                    <%= link_to "上线", toggle_status_admin_book_path(book), method: :put, class: "layui-btn layui-btn-xs", data: { confirm: '确认上线吗?' } %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        <% end %>
      </tbody>
    </table>

    <!-- 分页 -->
    <% if @books.total_pages > 1 %>
      <div id="pagination" style="margin-top: 20px; text-align: center;"></div>
    <% end %>
  </div>
</div>

<style>
  .layui-btn-group .layui-btn {
    margin: 0 2px;
  }

  .layui-btn-xs {
    padding: 0 6px;
    height: 24px;
    line-height: 24px;
    font-size: 12px;
  }
</style>

<script>
  layui.use(['laypage', 'form', 'layer'], function(){
    var laypage = layui.laypage,
        form = layui.form,
        layer = layui.layer;

    // 分页
    <% if @books.total_pages > 1 %>
    laypage.render({
      elem: 'pagination',
      count: <%= @books.total_entries %>,
      limit: <%= @books.per_page %>,
      curr: <%= @books.current_page %>,
      layout: ['count', 'prev', 'page', 'next', 'limit', 'skip'],
      jump: function(obj, first){
        if(!first){
          var url = new URL(window.location.href);
          url.searchParams.set('page', obj.curr);
          url.searchParams.set('per_page', obj.limit);
          window.location.href = url.toString();
        }
      }
    });
    <% end %>
  });
</script>
