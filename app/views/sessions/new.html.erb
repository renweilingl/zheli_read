<div class="login-card">                                                       
  <div class="login-header">                                                   
    <div class="login-logo">                                                   
      <i class="layui-icon layui-icon-release"></i>                            
    </div>                                                                     
    <h1>欢迎回来</h1>                                                          
    <p>登录您的账户以继续</p>                                                  
  </div>

  <div class="login-body">
    <% if alert %>
      <div class="layui-alert layui-alert-danger" style="background: #fff2f0; border-color: #ffccc7; color: #ff4d4f; margin-bottom: 20px; border-radius: 8px;">
        <i class="layui-icon layui-icon-close-fill"></i>
        <%= alert %>
      </div>
    <% end %>

    <% if notice %>
      <div class="layui-alert layui-alert-success" style="background: #f6ffed; border-color: #b7eb8f; color: #52c41a; margin-bottom: 20px; border-radius: 8px;">
        <i class="layui-icon layui-icon-ok-circle"></i>
        <%= notice %>
      </div>
    <% end %>

    <%= form_with url: login_path, local: true, class: "layui-form", id: "login-form" do |f| %>
      <div class="layui-form-item">
        <label class="layui-form-label">邮箱</label>
        <div class="layui-input-block">
          <div class="input-with-icon">
            <i class="layui-icon layui-icon-email input-icon" style="position: absolute; left: 14px; top: 50%; transform: translateY(-50%); font-size: 20px; color: #8c8c8c; z-index: 1;"></i>
            <%= f.email_field :email,
                placeholder: "请输入邮箱地址",
                required: true,
                class: "layui-input",
                style: "padding-left: 46px;",
                lay_verify: "required|email" %>
          </div>
        </div>
      </div>

      <div class="layui-form-item">                                            
        <label class="layui-form-label">密码</label>                           
        <div class="layui-input-block">                                        
          <div class="input-with-icon">                                        
            <i class="layui-icon layui-icon-password input-icon" style="position: absolute; left: 14px; top: 50%; transform: translateY(-50%); font-size: 20px; color: #8c8c8c; z-index: 1;"></i>
            <%= f.password_field :password,                                    
                placeholder: "请输入密码",                                     
                required: true,                                                
                class: "layui-input",                                          
                style: "padding-left: 46px;",                                  
                lay_verify: "required",                                        
                id: "password-field" %>                                        
          </div>                                                               
        </div>                                                                 
      </div> 

      <div class="layui-form-item" style="margin-top: 24px; margin-bottom: 0;">
        <button type="submit" class="layui-btn-login" lay-submit lay-filter="login">
          <i class="layui-icon layui-icon-ok"></i>                             
          登 录                                                                
        </button>                                                              
      </div> 
    <% end %>
  </div>
</div>

<script>                                                                       
    layui.use(['form', 'layer'], function(){                                     
      var form = layui.form,                                                     
          layer = layui.layer,                                                   
          $ = layui.$;                                                           
                                                                                 
      form.render();                                                             
                                                                                 
      $('.layui-input').on('focus', function(){                                  
        $(this).closest('.input-with-icon').find('.input-icon').css('color', '#52c41a');
      }).on('blur', function(){                                                  
        $(this).closest('.input-with-icon').find('.input-icon').css('color', '#8c8c8c');
      });
    }); 
</script>
