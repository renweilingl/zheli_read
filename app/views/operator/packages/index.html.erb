<div class="layui-tab">                                                          
  <div class="x-nav">
    <span class="layui-breadcrumb">                                              
      <a href="">运营管理</a>
      <a><cite>套餐管理</cite></a>
    </span>
    <%= render 'common/user_info' %>
  </div>

  <div class="x-body">
    <div class="layui-row">
      <div class="layui-col-3 text-right">
        <%= link_to :new_operator_package, class: 'layui-btn layui-bg-blue' do %>
          <i class="layui-icon"></i>新增套餐
        <% end %>
      </div>
    </div>

    <table class="layui-table">
      <thead>
        <tr>
          <th width="80">ID</th>
          <th>名称</th>
          <th>原价</th>
          <th>实际价格</th>
          <th>限时折扣</th>
          <th>折扣标签</th>
          <th>有效天数</th>
          <th>创建时间</th>
          <th width="120" style="text-align:center;">操作</th>
        </tr>
      </thead>
      <tbody>
        <% @packages.each do |r| %>
          <tr>
            <td><%= r.id %></td>
            <td><%= r.name %></td>
            <td><%= r.origin_price.round(2) %></td>
            <td><%= r.price.round(2) %></td>
            <td><%= r.is_discount? ? "是" : "否" %></td>
            <td><%= r.discount_tag %></td>
            <td><%= r.effective_days %></td>
            <td><%= r.created_at.strftime("%Y-%m-%d") %></td>
            <td style="text-align:center;">
              <div class="layui-btn-group">
                <%= link_to '编辑', edit_operator_package_path(r), class: "layui-btn layui-btn-sm" %>
                <%= link_to '删除', operator_package_path(r), method: :delete, class: "layui-btn layui-btn-sm", title: "删除", data: { confirm: "确定要删除此套餐吗？此操作不可恢复。" } %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>

  </div>
</div>
