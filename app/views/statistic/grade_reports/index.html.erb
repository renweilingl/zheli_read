<div class="layui-tab">
  <div class="x-nav">
    <span class="layui-breadcrumb">
      <a href="">统计报表</a>
      <a><cite>年龄分析</cite></a>
    </span>
    <%= render 'common/user_info' %>
  </div>
  <div class="x-body">
    <div class="layui-row">
      <div id="tpl-grades" style="width: 100%;height: 600px;"></div>
    </div>
  </div>
</div>

<script type="text/javascript">
  var data = [];

  <% @items.each do |x| %>
    data.push({value: <%= x[1] %>, name: "<%= x[0] %>"});
  <% end %>

  option = {
    title: {
      text: '用户年龄分布',
      //subtext: 'Fake Data',
      left: 'center'
    },
    tooltip: {
      trigger: 'item'
    },
    legend: {
      orient: 'vertical',
      left: 'left'
    },
    series: [
      {
        name: '用户年龄分布',
        type: 'pie',
        radius: '50%',
        data: data,
        emphasis: {
          itemStyle: {
            shadowBlur: 10,
            shadowOffsetX: 0,
            shadowColor: 'rgba(0, 0, 0, 0.5)'
          }
        }
      }
    ]
  };

  var echartsC = echarts.init(document.getElementById('tpl-grades'));
  echartsC.setOption(option);
</script>
